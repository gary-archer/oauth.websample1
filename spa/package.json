    "@types/mustache": "^4.2.5",
    "@types/node": "^24.10.3",
    "eslint": "^9.39.2",
    "rollup": "^4.59.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-livereload": "^2.0.5",
